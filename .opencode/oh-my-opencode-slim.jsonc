{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "loop-calculator",
  "setDefaultAgent": true,
  "autoUpdate": false,

  "presets": {
    "loop-calculator": {
      "orchestrator": {
        "model": "openai/gpt-5.5",
        "variant": "medium",
        "skills": ["*"],
        "mcps": ["*", "!context7"],
        "displayName": "orchestrator"
      },
      "oracle": {
        "model": "openai/gpt-5.5",
        "variant": "high",
        "skills": ["simplify"],
        "mcps": [],
        "displayName": "architect"
      },
      "explorer": {
        "model": "openai/gpt-5.4-mini",
        "variant": "low",
        "skills": [],
        "mcps": [],
        "displayName": "code-scout"
      },
      "librarian": {
        "model": "openai/gpt-5.4-mini",
        "variant": "low",
        "skills": [],
        "mcps": ["websearch", "grep_app"],
        "displayName": "researcher"
      },
      "designer": {
        "model": "openai/gpt-5.4-mini",
        "variant": "medium",
        "skills": ["agent-browser"],
        "mcps": [],
        "displayName": "ui-polish"
      },
      "fixer": {
        "model": "openai/gpt-5.4-mini",
        "variant": "low",
        "skills": [],
        "mcps": [],
        "displayName": "implementer"
      },
      "council": {
        "model": "openai/gpt-5.5",
        "variant": "high",
        "skills": [],
        "mcps": [],
        "displayName": "council"
      }
    }
  },

  "agents": {
    "trellis-keeper": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "skills": [],
      "mcps": [],
      "displayName": "trellis-keeper",
      "prompt": "You maintain Trellis task and workspace memory for Loop Calculator. Read AGENTS.md, .trellis/spec/loop-calculator/, the active task PRD, and recent workspace journals. Produce concise updates to task status, journal notes, risks, verification, and next steps. Do not edit source code.",
      "orchestratorPrompt": "@trellis-keeper\n- Role: Trellis memory and task-state maintainer for Loop Calculator\n- Delegate when: starting a task, saving session notes, updating PRD status, extracting durable lessons from a completed task\n- Do not delegate when: source-code implementation, test execution, visual UI edits, or backend behavior changes are required"
    }
  },

  "sessionManager": {
    "maxSessionsPerAgent": 3,
    "readContextMinLines": 20,
    "readContextMaxFiles": 10
  },

  "fallback": {
    "enabled": true,
    "timeoutMs": 30000,
    "retryDelayMs": 800,
    "retry_on_empty": true,
    "chains": {
      "orchestrator": ["openai/gpt-5.5", "openai/gpt-5.4"],
      "oracle": ["openai/gpt-5.5", "openai/gpt-5.4"],
      "explorer": ["openai/gpt-5.4-mini", "openai/gpt-5.4"],
      "librarian": ["openai/gpt-5.4-mini", "openai/gpt-5.4"],
      "designer": ["openai/gpt-5.4-mini", "openai/gpt-5.4"],
      "fixer": ["openai/gpt-5.4-mini", "openai/gpt-5.4"]
    }
  },

  "council": {
    "default_preset": "loop-calculator-review",
    "timeout": 180000,
    "councillor_execution_mode": "parallel",
    "councillor_retries": 2,
    "presets": {
      "loop-calculator-review": {
        "architecture": {
          "model": "openai/gpt-5.5",
          "variant": "high",
          "prompt": "Review architecture boundaries, calculation purity, API/schema consistency, and data ownership."
        },
        "implementation": {
          "model": "openai/gpt-5.4",
          "variant": "medium",
          "prompt": "Review implementation risk, missing tests, and practical maintainability."
        },
        "frontend": {
          "model": "openai/gpt-5.4-mini",
          "variant": "medium",
          "prompt": "Review Vue UI/state consistency, Tailwind usage, accessibility, and build risk."
        }
      }
    }
  }
}
